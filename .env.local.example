# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs (one per session type, shared across all advisors)
STRIPE_PRICE_QUICK=price_...
STRIPE_PRICE_WORKING=price_...
STRIPE_PRICE_STRATEGY=price_...

# Stripe webhook secret — get from https://dashboard.stripe.com/webhooks
# Enable event: checkout.session.completed
# For local dev: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Calendly ─────────────────────────────────────────────────────────────────
# Personal Access Token — https://app.calendly.com/integrations/api_webhooks
# Each advisor can have their own token; all fall back to CALENDLY_API_TOKEN.
CALENDLY_API_TOKEN=eyJ...
CALENDLY_API_TOKEN_CHRISTIAN=eyJ...
CALENDLY_API_TOKEN_MATT=eyJ...
CALENDLY_API_TOKEN_OMAR=eyJ...

# Scheduling page URLs — must exactly match what's in each advisor's Calendly account
CALENDLY_URL_CHRISTIAN_QUICK=https://calendly.com/christian-dfruitventures/quick-call
CALENDLY_URL_CHRISTIAN_WORKING=https://calendly.com/christian-dfruitventures/30min
CALENDLY_URL_CHRISTIAN_STRATEGY=https://calendly.com/christian-dfruitventures/strategy-session

CALENDLY_URL_MATT_QUICK=https://calendly.com/matt-dfruitventures/quick-call
CALENDLY_URL_MATT_WORKING=https://calendly.com/matt-dfruitventures/30min
CALENDLY_URL_MATT_STRATEGY=https://calendly.com/matt-dfruitventures/strategy-session

CALENDLY_URL_OMAR_QUICK=https://calendly.com/omar-dfruitventures/quick-call
CALENDLY_URL_OMAR_WORKING=https://calendly.com/omar-dfruitventures/30min
CALENDLY_URL_OMAR_STRATEGY=https://calendly.com/omar-dfruitventures/strategy-session

# ── Resend (calendar invites) ─────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_...

# Verified sender address. Use "onboarding@resend.dev" for local testing
# before verifying dfruitventures.com in the Resend dashboard.
EMAIL_FROM=Dragon Fruit Ventures <bookings@dfruitventures.com>

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://your-domain.com
