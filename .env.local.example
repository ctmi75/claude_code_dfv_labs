# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs (one per session type)
STRIPE_PRICE_DECK_REVIEW=price_...
STRIPE_PRICE_QUICK=price_...
STRIPE_PRICE_WORKING=price_...
STRIPE_PRICE_STRATEGY=price_...

# Stripe webhook secret — get from https://dashboard.stripe.com/webhooks
# Enable event: checkout.session.completed
# For local dev: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Google Calendar ───────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → create a project
# 2. Enable the "Google Calendar API"
# 3. Create a Service Account → generate a JSON key
# 4. Copy client_email and private_key from the JSON into the vars below
# 5. In each advisor's Google Calendar settings, share it with the service account
#    email and grant "Make changes to events" permission
# 6. Copy each calendar's ID (Settings → Integrate calendar → Calendar ID)

GOOGLE_SERVICE_ACCOUNT_EMAIL=dfv-booking@your-project.iam.gserviceaccount.com
# Paste the private_key value exactly as it appears in the JSON (including \n escapes)
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Per-advisor calendar IDs (use the advisor's primary calendar or a dedicated one)
GOOGLE_CALENDAR_ID_CHRISTIAN=christian@dfruitventures.com
GOOGLE_CALENDAR_ID_MATT=matt@dfruitventures.com
GOOGLE_CALENDAR_ID_OMAR=omar@dfruitventures.com

# Shared deck-review calendar — create one in Google Calendar and share it
# with all three partners AND the service account
GOOGLE_CALENDAR_ID_DECK_REVIEW=c_abc123...@group.calendar.google.com

# Fallback calendar used if a specific one isn't set
GOOGLE_CALENDAR_ID=primary

# ── Resend (payment confirmation emails) ──────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_...

# Verified sender address
EMAIL_FROM=Dragon Fruit Ventures <bookings@dfruitventures.com>

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://your-domain.com
